# .env.example — Bastion v3 secrets & runtime env template
# Copy to .env and fill in your values: cp .env.example .env
# NEVER commit .env to git. This file (.env.example) is safe to commit.
# Non-secret config lives in bastion.toml; any key there can be overridden with a
# BASTION__SECTION__KEY env var (config crate, "__" separator).
#
# Sections below are grouped by what consumes each var:
#   [CORE]   = read by the Rust daemon          [SKILLS] = read by the Python MCP skills
#   [DOCKER] = used by docker-compose/installer  [FUTURE] = not wired in v3 yet

# ══════════════════════════════════════════════════════════════════════════════
# [CORE] LLM provider API keys — provide at least one
# Model is picked by name in bastion.toml [agent] default_model (see provider/registry.rs):
#   "claude*"->Anthropic  "gpt*/o1/o3"->OpenAI  "gemini*"->Gemini  "*/*"->OpenRouter  else Ollama
# ══════════════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# Optional base-URL overrides (proxies / self-hosted gateways). Leave unset for defaults.
# GEMINI_BASE_URL=
# OPENROUTER_BASE_URL=

# ── [CORE] Ollama / local-inference egress target (privacy_tier=local-only personas) ──
# Address + token the daemon uses to reach a local inference endpoint.
# BASTION_INFER_ADDR=http://127.0.0.1:11434
# BASTION_INFER_TOKEN=

# ══════════════════════════════════════════════════════════════════════════════
# [CORE] Messaging channels
# v3 ships Telegram (long-polling, no inbound port) + optional webhook. See bastion.toml [channels].
# ══════════════════════════════════════════════════════════════════════════════
# Telegram (recommended) — token from @BotFather via /newbot
TELEGRAM_BOT_TOKEN=1234567890:ABC...

# ══════════════════════════════════════════════════════════════════════════════
# [CORE] Mobile app / cockpit / pokedev-cli + mesh
# Gate is BASTION_WEBHOOK_ADDR being SET (main.rs) — bastion.toml's
# channels.webhook.enabled key is currently unread/vestigial, not a real gate.
# ══════════════════════════════════════════════════════════════════════════════
# REQUIRED to start the webhook/cockpit — the daemon FAILS CLOSED if unset (WR-01).
# Random 32+ char secret that signs client session JWTs (Flutter app, pokedev-cli).
# Generate: openssl rand -hex 32
# NOTE: changing this invalidates existing app pairings (devices must re-pair).
# [DOCKER] installer.sh auto-generates this if missing — manual (cargo run) setups
# must set it themselves.
APP_JWT_SECRET=

# Bind address for the webhook/cockpit HTTP server (POST /webhook, GET /events SSE).
# Behind a TLS reverse proxy (caddy/nginx/traefik) in production — do not expose raw.
# [DOCKER] installer.sh sets this to 0.0.0.0:8080 by default (docker-compose.yml
# publishes host port 8080). Manual (cargo run) setups: uncomment to opt in.
# BASTION_WEBHOOK_ADDR=0.0.0.0:8080

# Stable owner id for this deployment (used by goals, memory tagging, mesh slices).
BASTION_OWNER_ID=_local

# ── Mesh (multi-owner peering — optional) ──
# MESH_OWNER_ID=
# Age keypair identity for this node. Changing it changes the node's mesh identity.
# Generate: age-keygen
# MESH_IDENTITY_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# [CORE] Skills bridge + observability + overrides
# ══════════════════════════════════════════════════════════════════════════════
# Directory the daemon loads agent skills from (defaults to ./skills).
# SKILLS_DIR=./skills

# OpenTelemetry (optional) — OTLP collector endpoint; content events are off by default.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# BASTION_OTEL_CONTENT_EVENTS=false

# Logging: level is controlled by RUST_LOG (the toml [logging] level was removed).
# RUST_LOG=info
# RUST_LOG_PATH=/bastion-data/bastion.log

# Memory recall by prompt injection (SEAM #2 MemoryRagProvider) — recall works with
# ANY provider, including terminal-agents that never emit tool_calls (PROV-09).
# Opt-in: providers with function-calling already get memory tools.
# BASTION_MEMORY_RAG=1

# Override bastion.toml values, e.g.:
# BASTION__AGENT__DEFAULT_MODEL=claude-opus-4-7
# BASTION__SESSION__DB_PATH=./.bastion/sessions.db   # local (non-Docker) runs
# Path to an alternate bastion.toml (defaults to ./bastion.toml):
# BASTION_CONFIG=

# ══════════════════════════════════════════════════════════════════════════════
# [SKILLS] Python MCP skill servers (onboarding, life-log, memupalace, …)
# These are consumed by the skill processes, NOT the Rust core.
# ══════════════════════════════════════════════════════════════════════════════
# TOTP onboarding auth (skills/onboarding) — generated during onboarding via pyotp
BASTION_TOTP_SECRET=
BASTION_SESSION_TTL_HOURS=8
BASTION_MAX_AUTH_ATTEMPTS=3

# life-log skill storage. Options: sqlite | supabase
DB_STRATEGY=sqlite
SQLITE_PATH=./db/life-log.db
SUPABASE_URL=
SUPABASE_KEY=

# Composio (850+ app integrations) — https://dashboard.composio.dev
COMPOSIO_CONSUMER_KEY=

# Timezone for date/time skills (calendar, agenda). Any IANA zone, e.g. America/Sao_Paulo
TIMEZONE=UTC

# ══════════════════════════════════════════════════════════════════════════════
# [DOCKER] Container runtime (set automatically by installer.sh)
# UID/GID of the host user so container-written files are never owned by root.
# Run: id -u && id -g
# ══════════════════════════════════════════════════════════════════════════════
BASTION_UID=1000
BASTION_GID=1000

# ══════════════════════════════════════════════════════════════════════════════
# [FUTURE] Not implemented in v3 core yet — left here as a roadmap marker (D-11).
# Discord / Slack / WhatsApp channels and Groq are community/future; setting them does nothing.
# ══════════════════════════════════════════════════════════════════════════════
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# WHATSAPP_API_URL=
# GROQ_API_KEY=
