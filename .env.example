# Bastion secrets and deployment environment.
# Copy to .env; never commit the resulting file. Non-secret behavior belongs in bastion.toml.

# LLM provider — configure at least the provider selected by [agent].default_model.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
# GEMINI_BASE_URL=
# OPENROUTER_BASE_URL=

# Canonical owner for local terminal/voice and operational tasks.
BASTION_OWNER_ID=_local

# Webhook, mobile and `bastion chat` pairing.
BASTION_WEBHOOK_ADDR=0.0.0.0:8080
APP_JWT_SECRET=
# Initial owner-scoped API/TUI token generated by installer.sh; rotate after onboarding.
BASTION_BOOTSTRAP_TOKEN=
# Public HTTPS URL advertised to peers, when applicable.
# BASTION_PUBLIC_URL=
# Client-side remote daemon URL used by `bastion chat`.
# BASTION_URL=http://127.0.0.1:8080
# BASTION_TOKEN=

# Private inference gateway used by Docker MCP sidecars.
BASTION_INFER_TOKEN=
# BASTION_INFER_ADDR=127.0.0.1:3000

# Messaging channel credentials. A channel also needs enabled=true in bastion.toml.
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=587

# Optional integrations and runtime services.
COMPOSIO_API_KEY=
# MESH_IDENTITY_KEY=
# MESH_OWNER_ID=
# VOICE_WAKE_WORD_MODEL_PATH=
# OTEL_EXPORTER_OTLP_ENDPOINT=
# BASTION_OTEL_STDOUT=false
# BASTION_OTEL_CONTENT_EVENTS=false
RUST_LOG=info

# Python skill configuration.
BASTION_TOTP_SECRET=
BASTION_SESSION_TTL_HOURS=8
BASTION_MAX_AUTH_ATTEMPTS=3
DB_STRATEGY=sqlite
SQLITE_PATH=./db/life-log.db
SUPABASE_URL=
SUPABASE_KEY=
TIMEZONE=UTC

# Docker host ownership.
BASTION_UID=1000
BASTION_GID=1000

# Any bastion.toml value can be overridden with BASTION__SECTION__KEY.
# BASTION__AGENT__DEFAULT_MODEL=gemini-2.5-flash
# BASTION__SESSION__DB_PATH=/bastion-data/sessions.db
# BASTION_CONFIG=bastion.toml
